# ---------- Frontend (exposed to browser) ----------
# Found at: Supabase project -> Settings -> API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Edge function endpoints. Defaults to <SUPABASE_URL>/functions/v1/<name> if unset.
VITE_ANALYZE_FUNCTION_URL=https://YOUR-PROJECT.supabase.co/functions/v1/analyze-plant
VITE_CHAT_FUNCTION_URL=https://YOUR-PROJECT.supabase.co/functions/v1/chat

# Web Push: VAPID PUBLIC key (URL-safe base64). Generate a keypair with:
#   npx web-push generate-vapid-keys
# The PUBLIC half goes here; the PRIVATE half is set as a Supabase secret.
VITE_VAPID_PUBLIC_KEY=YOUR-VAPID-PUBLIC-KEY

# ---------- Backend / Edge Function secrets (NEVER expose to browser) ----------
# Set in Supabase: `supabase secrets set KEY=VALUE`
#   XAI_API_KEY            xAI Grok API key
#   XAI_MODEL              e.g. grok-4-fast (default) or grok-4
#
# Push notifications:
#   VAPID_PUBLIC_KEY       Same value as above (no VITE_ prefix)
#   VAPID_PRIVATE_KEY      The private half from web-push keygen
#   VAPID_SUBJECT          mailto:you@example.com
#   SERVICE_ROLE_KEY       Supabase service-role key (bypasses RLS for cron)
#   CRON_SHARED_SECRET     Random string the pg_cron job sends in X-Cron-Secret
XAI_API_KEY=xai-YOUR-KEY
XAI_MODEL=grok-4-fast
VAPID_PUBLIC_KEY=YOUR-VAPID-PUBLIC-KEY
VAPID_PRIVATE_KEY=YOUR-VAPID-PRIVATE-KEY
VAPID_SUBJECT=mailto:you@example.com
SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
CRON_SHARED_SECRET=generate-a-random-string
