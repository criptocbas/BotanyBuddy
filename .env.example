# ---------- Frontend (exposed to browser) ----------
# Found at: Supabase project -> Settings -> API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Grok Edge Function endpoint (your Supabase project URL + function path)
# This is the only Grok-related value the frontend knows about.
VITE_ANALYZE_FUNCTION_URL=https://YOUR-PROJECT.supabase.co/functions/v1/analyze-plant

# ---------- Backend / Edge Function (NEVER expose to browser) ----------
# Set these in Supabase: Project -> Edge Functions -> Secrets
#   supabase secrets set XAI_API_KEY=xai-...
#   supabase secrets set XAI_MODEL=grok-4-fast
XAI_API_KEY=xai-YOUR-KEY
XAI_MODEL=grok-4-fast
